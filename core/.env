# ============================================================
# RedTeam Professional Framework - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---------------------- System Mode ----------------------
# simulation_mode: true = safe mode (no real connections)
# production_mode: false = use real VPN/Tor/Exploits (requires authorization)
SIMULATION_MODE=true
PRODUCTION_MODE=false
LAB_MODE=true

# ---------------------- OPSEC Shield ----------------------
# VPN Chain Configuration
VPN_ENABLED=false
VPN_PROVIDERS=protonvpn,mullvad,ivpn
VPN_EXCLUDED_COUNTRIES=US,UK,AU,CA,NZ
VPN_CHAIN_LENGTH=3
VPN_ROTATION_INTERVAL_SECONDS=3600

# ProtonVPN credentials (if used)
PROTONVPN_USERNAME=
PROTONVPN_PASSWORD=
PROTONVPN_PLAN=free

# Mullvad credentials
MULLVAD_ACCOUNT=

# Tor Configuration
TOR_ENABLED=false
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_PASSWORD=
TOR_USE_BRIDGES=true
TOR_BRIDGES=obfs4 192.95.36.142:443 C6A5B4E5...,obfs4 45.145.95.6:27015 E8D4B2F9...

# Traffic Obfuscation
OBFUSCATION_METHOD=obfs4
MIMIC_PROTOCOL=https

# Dead Man's Switch
DMS_ENABLED=true
DMS_INACTIVITY_TIMEOUT_HOURS=72
DMS_AUTO_WIPE=true
DMS_ALERT_CHANNEL=signal
SIGNAL_PHONE_NUMBER=
SIGNAL_RECEIVER=

# ---------------------- Hacker Brain ----------------------
# LLM Configuration (local Ollama)
LLM_ENABLED=false
LLM_MODEL=llama3
LLM_OLLAMA_URL=http://localhost:11434
LLM_TEMPERATURE=0.7

# Decision Engine
EXPERIENCE_LEVEL=expert  # novice, intermediate, expert, elite
RISK_THRESHOLD=0.6       # minimum success probability to proceed

# ---------------------- Vulnerability Hunter ----------------------
# Scanner Configuration
SCANNER_CONCURRENT_REQUESTS=10
SCANNER_REQUEST_TIMEOUT=30
SCANNER_RATE_LIMIT=0       # requests per second (0 = unlimited)
SCANNER_RANDOM_DELAY_MIN=0.1
SCANNER_RANDOM_DELAY_MAX=1.0

# Safe domains (only scanned in lab mode)
SAFE_DOMAINS=localhost,127.0.0.1,192.168.,10.0.,172.16.,test.,example.com,dvwa,metasploitable

# ---------------------- Exploit Developer ----------------------
# Allow real exploit execution (requires PRODUCTION_MODE=true)
ALLOW_EXPLOIT_EXECUTION=false

# Default reverse shell settings
REVERSE_SHELL_IP=127.0.0.1
REVERSE_SHELL_PORT=4444

# msfvenom path (for shellcode generation)
MSFVENOM_PATH=msfvenom

# ---------------------- Backdoor Factory ----------------------
# Persistence settings
PERSISTENCE_HIDE_FROM_USER=true
PERSISTENCE_USE_LEGITIMATE_NAMES=true

# Implant configuration
IMPLANT_BEACON_INTERVAL=60
IMPLANT_JITTER=0.3
IMPLANT_SLEEP_PATTERN=jittered
IMPLANT_FILELESS=true

# ---------------------- C2 Channel ----------------------
# C2 Server Configuration
C2_ENABLED=true
C2_SERVER_HOST=0.0.0.0
C2_SERVER_PORT=8000
C2_SERVER_URL=https://c2.internal.local

# Domain Fronting (HTTPS mimicry)
C2_FRONT_DOMAIN=cloudflare.com
C2_REAL_DOMAIN=your-c2-domain.com

# DNS Tunnel
DNS_TUNNEL_DOMAIN=your-dns-domain.com
DNS_SERVER=8.8.8.8

# Steganography (social media account)
STEGANOGRAPHY_SOCIAL_ACCOUNT=twitter@your_account

# ---------------------- Self-Learning ----------------------
# Experience Database
EXPERIENCE_DB_PATH=./data/experiences.json
VECTOR_STORE_PATH=./data/chroma_db
KNOWLEDGE_GRAPH_URI=bolt://localhost:7687
KNOWLEDGE_GRAPH_USER=neo4j
KNOWLEDGE_GRAPH_PASSWORD=password

# Reinforcement Learning
RL_ENABLED=false
RL_POLICY_NETWORK=simple  # simple or pytorch
RL_REPLAY_BUFFER_SIZE=10000

# ---------------------- Logging & Monitoring ----------------------
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or console
LOG_FILE=./logs/redteam.log

# Prometheus metrics
METRICS_ENABLED=false
METRICS_PORT=9090

# ---------------------- Authorization (Legal) ----------------------
# Required for production mode - must be set to true to enable real attacks
AUTHORIZED_ENGAGEMENT=false
AUTHORIZATION_TOKEN=
CONTRACT_ID=
CLIENT_NAME=

# ---------------------- Development ----------------------
# Debug mode (more verbose, unsafe for production)
DEBUG=false
PROFILE=false